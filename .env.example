# ─────────────────────────────────────────────────────────────────────────────
# DocGen — Environment Variable Template
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq Cloud LLM (optional) ─────────────────────────────────────────────────
# Get your key at https://console.groq.com/keys
# Without this, docstrings are generated using the offline template engine only.
GROQ_API_KEY=gsk_your_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev default: http://localhost:5173
# Production: your Vercel URL, e.g. https://docgen.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Session Storage ───────────────────────────────────────────────────────────
# Where uploaded files and session state are stored.
# Local default (relative to CWD): leave commented out
# Render / cloud: use /tmp so it's always writable
# SESSION_DIR=/tmp/autodocstring_sessions
# BACKUP_DIR=/tmp/autodocstring_backup
